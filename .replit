modules = ["python-3.11", "postgresql-16"]
[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "app.py", "--server.port", "5000"]

[nix]
channel = "stable-25_05"
packages = ["alsa-lib", "at-spi2-atk", "cairo", "cargo", "cups", "dbus", "expat", "ffmpeg-full", "freetype", "ghostscript", "gitFull", "glib", "glibcLocales", "gobject-introspection", "gtk3", "libdrm", "libiconv", "libxkbcommon", "mesa", "nspr", "nss", "pango", "pkg-config", "playwright-driver", "qhull", "rustc", "tcl", "tk", "xcodebuild", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[userenv]

[userenv.shared]
BRAVE_API_KEY = "BSAtIZRmoUdUOdOSLdIfER4_IpWSEji"

[agent]
integrations = ["python_openai_ai_integrations:1.0.0"]
